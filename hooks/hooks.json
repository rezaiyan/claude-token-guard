{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/agent_guard.py\""
          }
        ],
        "description": "Block expensive Explore/Plan agents — use Grep, Glob, Read instead"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/bash_trimmer.py\""
          }
        ],
        "description": "Rewrite verbose Bash commands (git log, npm list, pytest, gradlew) to token-efficient equivalents"
      }
    ]
  }
}
